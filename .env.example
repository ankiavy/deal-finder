# Application
APP_NAME=Deal Finder API
DEBUG=true
BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql+asyncpg://dealuser:dealpass@localhost:5432/dealfinder

# Redis
REDIS_URL=redis://localhost:6379/0

# Amazon Product Advertising API (PAAPI 5.0)
AMAZON_ACCESS_KEY=your_amazon_access_key
AMAZON_SECRET_KEY=your_amazon_secret_key
AMAZON_PARTNER_TAG=your-21       # e.g., yoursite-21
AMAZON_REGION=in

# Flipkart Affiliate API
FLIPKART_API_TOKEN=your_flipkart_token

# Cache TTL (seconds)
SEARCH_CACHE_TTL=300
DEALS_CACHE_TTL=600

# Use mock data when APIs are not configured (true for development)
USE_MOCK_DATA=true
